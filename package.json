{
  "name": "volt",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "prompts:build": "node scripts/build-prompts-index.mjs",
    "cleanup": "node scripts/cleanup-before-dev.mjs",
    "sidecars:node": "node scripts/prepare-node-sidecar.mjs",
    "sidecars:rg": "node scripts/prepare-rg-sidecar.mjs",
    "sidecars:rg:strict": "node scripts/prepare-rg-sidecar.mjs --strict",
    "sidecars:all": "npm run sidecars:node && npm run sidecars:rg",
    "dev:with-sidecars": "npm run cleanup && npm run sidecars:all && vite dev",
    "build:with-sidecars": "npm run sidecars:node && npm run sidecars:rg:strict && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@iconify-json/codicon": "^1.2.36",
    "@iconify-json/vscode-icons": "^1.2.37",
    "@iconify/svelte": "^5.1.0",
    "@tailwindcss/language-server": "^0.14.29",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "marked": "^17.0.1",
    "monaco-editor": "^0.55.1",
    "svelte-language-server": "^0.17.28",
    "svelte-streamdown": "^3.0.1",
    "typescript-language-server": "^5.1.3",
    "vscode-langservers-extracted": "^4.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.53.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tauri-apps/cli": "^2",
    "eslint": "^10.0.2",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.3.0",
    "svelte": "^5.53.3",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.3",
    "vitest": "^4.0.16"

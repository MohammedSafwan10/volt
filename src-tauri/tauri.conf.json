{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "volt",
  "version": "0.1.0",
  "identifier": "com.admin.volt",
  "build": {
    "beforeDevCommand": "npm run dev:with-sidecars",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:with-sidecars",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "volt",
        "width": 800,
        "height": 600,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../node_modules/**/*"
    ],
    "externalBin": [
      "binaries/node"
    ]
  }
}

{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "remote": {
    "urls": [
      "http://localhost:1420",
      "https://localhost:1420",
      "http://127.0.0.1:1420",
      "https://127.0.0.1:1420",
      "http://0.0.0.0:1420",
      "https://0.0.0.0:1420"
    ]
  },
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:webview:default",
    "core:webview:allow-set-webview-zoom",
    "core:webview:allow-create-webview",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-set-webview-position",
    "core:webview:allow-set-webview-size",
    "core:webview:allow-webview-close",
    "core:window:default",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:path:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$LOCALDATA/**"
        },
        {
          "path": "$TEMP/**"
        },
        {
          "path": "$CACHE/**"
        },
        {
          "path": "$RESOURCE/**"
        }
      ]
    },
    "opener:allow-reveal-item-in-dir",
    "dialog:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$LOCALDATA/**"
        },
        {
          "path": "$TEMP/**"
        },
        {
          "path": "$CACHE/**"
        },
        {
          "path": "$RESOURCE/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$LOCALDATA/**"
        },
        {
          "path": "$TEMP/**"
        },
        {
          "path": "$CACHE/**"
        },
        {
          "path": "$RESOURCE/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$LOCALDATA/**"
        },
        {
          "path": "$TEMP/**"
        },
        {
          "path": "$CACHE/**"
        },
        {
          "path": "$RESOURCE/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$LOCALDATA/**"
        },
        {
          "path": "$TEMP/**"
        },
        {
          "path": "$CACHE/**"
        },
        {
          "path": "$RESOURCE/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-watch",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$APPDATA/**" },
        { "path": "$LOCALDATA/**" },
        { "path": "$TEMP/**" },
        { "path": "$CACHE/**" },
        { "path": "$RESOURCE/**" }
      ]
    },
    {
      "identifier": "fs:allow-unwatch",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$APPDATA/**" },
        { "path": "$LOCALDATA/**" },
        { "path": "$TEMP/**" },
        { "path": "$CACHE/**" },
        { "path": "$RESOURCE/**" }
      ]
    }
  ]
}

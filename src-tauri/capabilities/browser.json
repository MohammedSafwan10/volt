{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "browser",
  "description": "Capability for embedded browser webview",
  "remote": {
    "urls": [
      "http://localhost:*",
      "https://localhost:*",
      "http://127.0.0.1:*",
      "https://127.0.0.1:*"
    ]
  },
  "windows": [
    "volt-browser"
  ],
  "permissions": [
    "core:default"
  ]
}
